import fitz  # PyMuPDF
import re
from typing import List, Tuple

def extract_qa_pairs(file_path: str) -> List[Tuple[str, str]]:
    """Extract question-answer pairs from PDF text."""
    doc = fitz.open(file_path)
    text = ""
    for page in doc:
        text += page.get_text()
    doc.close()
    # Simple regex: "1. question text\nAnswer: answer text"
    pattern = r"(\d+)\.\s*(.+?)\nAnswer:\s*(.+)"
    pairs = re.findall(pattern, text, re.DOTALL)
    return [(q.strip(), a.strip()) for _, q, a in pairs]
PYEOF

cat > backend/app/services/distractor.py <<'PYEOF'
import random
import os
from openai import OpenAI
from app.core.config import settings

FALLBACK_DISTRACTORS = {
    "capital": ["Chittagong", "Sylhet", "Rajshahi"],
    "planet": ["Earth", "Mars", "Venus"],
    # generic fallback
    "default": ["Option A", "Option B", "Option C"]
}

def generate_distractors(question: str, correct: str) -> list[str]:
    """Generate 3 plausible wrong options. Uses OpenAI if available, else simple fallback."""
    if settings.OPENAI_API_KEY and settings.OPENAI_API_KEY != "sk-...":
        client = OpenAI(api_key=settings.OPENAI_API_KEY)
        try:
            response = client.chat.completions.create(
                model="gpt-3.5-turbo",
                messages=[
                    {"role": "system", "content": "Generate exactly 3 plausible but incorrect multiple-choice distractors."},
                    {"role": "user", "content": f"Question: {question}\nCorrect answer: {correct}\nReturn only a JSON list of 3 strings."}
                ],
                temperature=0.7
            )
            import json
            dist = json.loads(response.choices[0].message.content)
            return dist[:3]
        except Exception:
            pass
    # Fallback
    for keyword, distractors in FALLBACK_DISTRACTORS.items():
        if keyword in question.lower():
            return distractors[:3]
    # generic fallback
    return [f"{correct} (wrong)", f"Not {correct}", f"Almost {correct}"]
PYEOF

